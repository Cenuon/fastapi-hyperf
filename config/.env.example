# ===================================
# 生产安全检查表
# ===================================
# 在部署到生产环境之前，请确保：
# 1. 生成具有高熵值的强SECRET_KEY
#    示例：python -c "import secrets; print(secrets.token_urlsafe(64))"
# 2. 设置唯一的数据库密码（避免使用默认值如'postgres'）
# 3. 为所有实例设置 Redis 密码：
#    - CACHE_REDIS_PASSWORD（用于缓存操作）
#    - RATE_LIMITER_REDIS_PASSWORD（用于限流）
# 4. 为不同的服务使用单独的 Redis 实例/数据库：
#    - 缓存：CACHE_REDIS_DB=0（默认）
#    - 限流器：RATE_LIMITER_REDIS_DB=1（默认）
#    - Taskiq: TASKIQ_REDIS_DB=3（默认）
# 5. 限制CORS_ORIGINS到特定域名（避免）
# 6. 设置强管理员凭证（ADMIN_USERNAME, ADMIN_PASSWORD）
# 7. 根据您的安全需求审查会话超时设置
# 8. 将 ENVIRONMENT 设置为 production 以启用安全验证
# 9. 使用强凭证配置RabbitMQ（避免使用guest/guest）
# 10. 在生产环境中设置 TASKIQ_ENABLED=true 以启用后台任务处理

# ===================================
# 环境配置
# ===================================
# 选项: production, staging, development, local
ENVIRONMENT=development

# ===================================
# 数据库配置
# ===================================
POSTGRES_USER=hyperf
POSTGRES_PASSWORD=kFZnYz4HrFa65Thw
POSTGRES_DB=hyperf
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_SYNC_PREFIX=postgresql://
POSTGRES_ASYNC_PREFIX=postgresql+asyncpg://
CREATE_TABLES_ON_STARTUP=true

# ===================================
# 缓存配置
# ===================================
CACHE_ENABLED=true
# 选项: memcached, redis
CACHE_BACKEND=redis
DEFAULT_CACHE_EXPIRATION=3600

# 客户端缓存设置
CLIENT_CACHE_ENABLED=true
CLIENT_CACHE_MAX_AGE=60

# 缓存Memcached设置（使用CACHE_BACKEND=memcached时）
#CACHE_MEMCACHED_HOST=localhost
#CACHE_MEMCACHED_PORT=11211
#CACHE_MEMCACHED_POOL_SIZE=10
#CACHE_MEMCACHED_CONNECT_TIMEOUT=5

# 缓存Redis设置（使用CACHE_BACKEND=redis时）
# 对于Docker Compose：使用“redis”（服务名称）
# 本地开发不使用 Docker 时，请使用 'localhost'
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=6379
CACHE_REDIS_DB=2
CACHE_REDIS_PASSWORD=redis_YtpHkQ
CACHE_REDIS_CONNECT_TIMEOUT=5
CACHE_REDIS_POOL_SIZE=10

# ===================================
# 速率限制配置
# ===================================
RATE_LIMITER_ENABLED=true
# 选项: memcached, redis
RATE_LIMITER_BACKEND=redis
RATE_LIMITER_FAIL_OPEN=true
DEFAULT_RATE_LIMIT_LIMIT=100
DEFAULT_RATE_LIMIT_PERIOD=60

# 速率限制器Memcached设置（使用RATE_LIMITER_BACKEND=memcached时）
#RATE_LIMITER_MEMCACHED_HOST=localhost
#RATE_LIMITER_MEMCACHED_PORT=11211
#RATE_LIMITER_MEMCACHED_POOL_SIZE=10

# 速率限制器Redis设置（使用RATE_LIMITER_BACKEND=redis时）
# 默认使用 DB 1 以与缓存区（使用 DB 0）区分开
# 对于 Docker Compose：使用 'redis'（服务名称）
# 本地开发不使用 Docker 时，请使用 'localhost'
RATE_LIMITER_REDIS_HOST=localhost
RATE_LIMITER_REDIS_PORT=6379
RATE_LIMITER_REDIS_DB=3
RATE_LIMITER_REDIS_PASSWORD=redis_YtpHkQ
RATE_LIMITER_REDIS_CONNECT_TIMEOUT=5
RATE_LIMITER_REDIS_POOL_SIZE=10

# ===================================
# Taskiq配置
# ===================================
# 启用/禁用 Taskiq 异步任务处理
TASKIQ_ENABLED=true
# 代理类型：“redis”或“rabbitmq”
TASKIQ_BROKER_TYPE=redis

# Redis 消息代理设置（当 TASKIQ_BROKER_TYPE=redis 时使用）
# 对于 Docker Compose：使用 'redis'（服务名称）
# 本地开发不使用 Docker 时，请使用 'localhost'
TASKIQ_REDIS_HOST=localhost
TASKIQ_REDIS_PORT=6379
TASKIQ_REDIS_DB=4
TASKIQ_REDIS_PASSWORD=redis_YtpHkQ

# RabbitMQ 代理设置（当 TASKIQ_BROKER_TYPE=rabbitmq 时使用）
#TASKIQ_RABBITMQ_HOST=localhost
#TASKIQ_RABBITMQ_PORT=5672
#TASKIQ_RABBITMQ_USER=guest
#TASKIQ_RABBITMQ_PASSWORD=guest
#TASKIQ_RABBITMQ_VHOST=/

# Taskiq 工作者设置
TASKIQ_WORKER_CONCURRENCY=2
TASKIQ_MAX_TASKS_PER_WORKER=1000


# ===================================
# Web服务器配置
# ===================================
# CORS 设置
CORS_ENABLED=true
# 允许的来源列表，用逗号分隔
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# 压缩设置
GZIP_ENABLED=true
GZIP_MINIMUM_SIZE=1000

# API文档设置
ENABLE_DOCS_IN_PRODUCTION=false
OPENAPI_PREFIX=

# ===================================
# 认证与安全
# ===================================
SECRET_KEY=insecure-secret-key-change-this-in-production

# 生产安全验证
# 自动验证生产环境中的安全设置
PRODUCTION_SECURITY_VALIDATION_ENABLED=true
PRODUCTION_SECURITY_STRICT_MODE=false

# 会话管理
SESSION_TIMEOUT_MINUTES=30
SESSION_CLEANUP_INTERVAL_MINUTES=15
MAX_SESSIONS_PER_USER=5
SESSION_SECURE_COOKIES=true
SESSION_BACKEND=redis
SESSION_COOKIE_MAX_AGE=86400

# CSRF防护
# 用于开发/测试时设为 false 以禁用 CSRF 验证
CSRF_ENABLED=true

# 登录频率限制
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15

# ===================================
# 管理界面（SQLAdmin）
# ===================================
# 启用/禁用管理界面
ADMIN_ENABLED=false

# ===================================
# OAuth 配置
# ===================================
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# Google 配置
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# GitHub 配置
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ===================================
# 应用设置
# ===================================
DEBUG=false
APP_NAME="FastAPI Hyperf"
APP_DESCRIPTION="FastAPI Hyperf"
VERSION=0.0.1
CONTACT_NAME=Support
CONTACT_EMAIL=support@ympip.com
LICENSE_NAME=MIT

# API设置（可选覆盖）
# API_PREFIX=/api
# DOCS_URL=/docs
# REDOC_URL=/redoc

# ===================================
# 初始设置配置
# ===================================
# 管理员用户设置（初始设置）
ADMIN_NAME=admin
ADMIN_EMAIL=admin@admin.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123*&$